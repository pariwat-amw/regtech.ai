# .env file for Smart Workplace configuration

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# Application Settings
APP_NAME=Smart Workplace - Regtech.AI
APP_VERSION=1.0.0

# Security Settings
SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# Database Configuration (for future expansion)
DATABASE_URL=sqlite:///smart_workplace.db

# AI/ML Configuration
ML_MODEL_UPDATE_INTERVAL=24  # hours
WORKSPACE_OPTIMIZATION_THRESHOLD=0.75

# Compliance Settings
COMPLIANCE_CHECK_INTERVAL=7  # days
DEFAULT_COMPLIANCE_THRESHOLD=75  # percentage

# Meeting Settings
DEFAULT_MEETING_DURATION=60  # minutes
MAX_MEETING_DURATION=480  # minutes (8 hours)
MEETING_ROOM_CAPACITY_SMALL=2
MEETING_ROOM_CAPACITY_MEDIUM=5
MEETING_ROOM_CAPACITY_LARGE=10

# Workspace Settings
TOTAL_WORKSPACE_CAPACITY=100
WORKSPACE_ZONES=3